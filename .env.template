# Groq API Configuration
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: LLM Model configurations
# Default recommended model for general tasks
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative smaller model (faster, lower rate limit impact)
# GROQ_MODEL=llama-3.1-8b-instant

# Optional: Audio configurations
# Whisper model size (tiny, base, small, medium, large-v3)
# Base is recommended for good accuracy-speed balance on CPU.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# TTS Voice configuration (e.g. en-US-GuyNeural, en-US-AriaNeural)
TTS_VOICE=en-US-GuyNeural
